{
  "slug": "synco-cross-rate",
  "name": "Synco Cross-Rate",
  "description": "Derives a cross-rate between two assets by fetching both Pyth prices and dividing base by quote. Returns JSON with the computed rate and timestamp.",
  "version": "1.0.0",
  "deployments": {
    "testnet": {
      "oracleProgramId": "721f46a151956d56e5b0cf31c7486352ad22c50876c3698d5ebed9b96f7719e7",
      "dateDeployed": "2026-04-06T14:30:00.000Z",
      "rustToolchain": "1.90.0"
    }
  },
  "inputSchema": {
    "type": "object",
    "required": ["base_feed_id", "quote_feed_id"],
    "properties": {
      "base_feed_id": {
        "type": "string",
        "description": "Pyth feed ID for the base asset (e.g. ETH/USD)"
      },
      "quote_feed_id": {
        "type": "string",
        "description": "Pyth feed ID for the quote asset (e.g. USDC/USD). The fetcher divides base by quote automatically."
      },
      "scale": {
        "type": "integer",
        "description": "Optional power-of-10 scaling factor applied to the cross-rate"
      }
    }
  },
  "outputSchema": {
    "type": "object",
    "required": ["cross_rate", "timestamp"],
    "properties": {
      "cross_rate": {
        "type": "string",
        "description": "Decimal cross-rate as string (base / quote)"
      },
      "timestamp": {
        "type": "string",
        "format": "date-time",
        "description": "ISO 8601 timestamp of the price data"
      }
    }
  },
  "dataSources": [
    {
      "id": "pyth",
      "name": "Pyth Network",
      "url": "https://pyth.network",
      "role": "primary"
    }
  ],
  "tags": [
    "crypto",
    "basic",
    "real-time",
    "pyth",
    "community"
  ],
  "repository": "https://github.com/jasperdg/synco",
  "author": {
    "name": "Synco Finance",
    "github": "jasperdg"
  },
  "examples": [
    {
      "name": "ETH/USDC cross-rate",
      "input": {
        "base_feed_id": "0xff61491a931112ddf1bd8147cd1b641375f79f5825126d665480874634fd0ace",
        "quote_feed_id": "0xeaa020c61cc479712813461ce153894a96a6c00b21ed0cfc2798d1f9a9e9c94a"
      },
      "expectedOutput": {
        "cross_rate": "3000.12345",
        "timestamp": "2026-04-01T12:00:00Z"
      }
    }
  ]
}
